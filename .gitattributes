# Auto detect text files and perform LF normalization
* text=auto

# Source files
*.ts     text eol=lf
*.tsx    text eol=lf
*.js     text eol=lf
*.jsx    text eol=lf
*.rs     text eol=lf
*.toml   text eol=lf
*.json   text eol=lf
*.md     text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.sh     text eol=lf

# Binary files — never modify
*.exe    binary
*.dll    binary
*.so     binary
*.dylib  binary
*.png    binary
*.jpg    binary
*.ico    binary
*.icns   binary
